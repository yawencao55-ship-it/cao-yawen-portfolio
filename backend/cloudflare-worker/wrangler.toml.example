name = "portfolio-message-api"
main = "src/index.js"
compatibility_date = "2026-03-04"

[[d1_databases]]
binding = "DB"
database_name = "portfolio_messages"
database_id = "YOUR_D1_DATABASE_ID"

[[kv_namespaces]]
binding = "RATE_LIMIT_KV"
id = "YOUR_KV_NAMESPACE_ID"

[vars]
ALLOWED_ORIGINS = "https://yawencao55-ship-it.github.io"
RATE_LIMIT_MAX = "5"
RATE_LIMIT_WINDOW_SEC = "600"
